# Platinum Heritage CRM — environment template
# Copy to .env and fill in values. Never commit real secrets.

# --- Core ---
FLASK_ENV=development
# production | development | testing
SESSION_SECRET=change-me-to-a-long-random-string
# Optional alias: FLASK_SECRET_KEY=

# SQLite (local) or Postgres (prod)
DATABASE_URL=sqlite:///real_estate_crm.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/gptvli

# --- Security ---
ENABLE_CSRF=0
# Set to 1 in production (auto-on when FLASK_ENV=production)
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
# ALLOW_INSECURE_SECRET=0
# ENABLE_CSP=0
# Admin console (/admin/login) — change in production (weak defaults refused).
# ADMIN_PASSWORD=change-me-to-a-strong-admin-password
# ALLOW_WEAK_ADMIN_PASSWORD=0

# --- UI ---
USE_TAILWIND_CDN=1
# 0 = use static/css/tailwind-ph.css (run: npm run build:css)
# 1 = Tailwind CDN (local UI only)

# --- AI / Gemini ---
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# Multimodal AI form assist (suggestions only; never auto-saves CRM)
# ENABLE_AI_FORM_ASSIST=0
# AI_FORM_AUDIT_STORAGE_ROOT=instance/ai_form_audit
# AI_FORM_RETENTION_DAYS=90
# AI_FORM_RETENTION_SCHEDULE_ENABLED=0
# AI_FORM_FAST_MODEL=gemini-2.5-flash

# --- SMS ---
SMS_PROVIDER=log
# melipayamak | log
# MELIPAYAMAK_USERNAME=
# MELIPAYAMAK_PASSWORD=
# MELIPAYAMAK_FROM=

# --- Geocoding ---
GEOCODE_PROVIDER=auto
# auto | nominatim | off
# GEOCODE_USER_AGENT=PlatinumHeritageCRM/1.0 (ops@example.com)

# --- Matching (always-on rematch + agent alerts) ---
# Drain RematchQueue every N seconds (default 60). Min 15.
# REMATCH_QUEUE_INTERVAL_SECONDS=60
# Or minutes: REMATCH_QUEUE_INTERVAL_MINUTES=1
# Full safety-net matching sweep (default 15 minutes)
# MATCHING_INTERVAL_MINUTES=15
# REMATCH_QUEUE_BATCH_SIZE=50
# REMATCH_QUEUE_MAX_RETRIES=5
# REMATCH_STALE_PROCESSING_MINUTES=15
# MATCHER_MIN_SCORE=0.5
# MATCHER_NOTIFICATION_THRESHOLD=0.7
# MATCHER_HIGH_PRIORITY_THRESHOLD=0.85
# Only re-alert when score rises by at least this amount
# MATCHER_SCORE_IMPROVE_DELTA=0.05
# MATCHER_NOTIFY_DEDUPE=1
# MATCHER_EMAIL_ON_HIGH=0
# Multi-parameter hybrid score weights (auto-normalized; defaults shown)
# SEMANTIC_WEIGHT=0.35
# BUDGET_WEIGHT=0.20
# LOCATION_WEIGHT=0.15
# TYPE_WEIGHT=0.10
# ROOMS_WEIGHT=0.10
# AMENITIES_WEIGHT=0.05
# SIZE_WEIGHT=0.05
# Legacy (splits into TYPE+ROOMS if TYPE/ROOMS unset): REQUIREMENTS_WEIGHT=0.15
# Hard filters on always-on prefilter
# MATCHING_STRICT_TYPE=0
# MATCHING_STRICT_LOCATION=0
# MATCHING_BEDROOM_TOLERANCE=1
# MATCHING_CANDIDATE_TOP_N=15

# --- CRM search / intelligence ---
# ENABLE_GLOBAL_SEARCH=1
# Property synonym expand (default off). Admin UI /admin/vocab always available.
# Seed values for first DB row of intelligence_settings only.
# After that, use Admin → Intelligence (/admin/intelligence) to toggle ON/OFF.
# Emergency: INTELLIGENCE_SETTINGS_USE_ENV=1 forces env over DB.
ENABLE_VOCAB_ENRICHMENT=0
ENABLE_VOCAB_OCCURRENCES=0
ENABLE_HYBRID_SEARCH=0
ENABLE_AI_CONTEXT=0
ENABLE_AI_ANSWER=0
# AI_CONTEXT_MAX_CHARS=8000
ENABLE_DERIVED_EDGES=0
ENABLE_SEARCH_SHADOW=0
ENABLE_DESCRIPTION_SEARCH=0
ENABLE_NL_QUERY_PARSE=0









# --- Optional ---
# PREFERRED_URL_SCHEME=https
# SESSION_LIFETIME_SECONDS=43200

# --- Docker Compose (profile: prod) ---
# Required for prod profile (compose refuses weak/missing values):
# SESSION_SECRET=<long-random-string>
# POSTGRES_PASSWORD=<strong-password>
# Optional:
# POSTGRES_USER=gptvli
# POSTGRES_DB=gptvli
# POSTGRES_PORT=5432
# WEB_PORT=8000
# RUN_MIGRATIONS=1
# MIGRATION_RETRIES=10
# MIGRATION_RETRY_DELAY=3
# REDIS_URL=redis://redis:6379/0

# Copy to .env and fill in real values. Never commit .env.

# Flask CRM
SESSION_SECRET=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///real_estate_crm.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/real_estate_crm

# AI (Google Gemini) — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini

# Optional Redis (docker compose --profile crm)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional CSRF
ENABLE_CSRF=0

# --- Experimental matching stack only (docs/matching-platform.md) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changemeplease
ENVIRONMENT=development
LOG_LEVEL=info
WORKER_CONCURRENCY=4

# Platinum Heritage CRM — environment template
# Copy to .env and fill in values. Never commit real secrets.

# --- Core ---
FLASK_ENV=development
# production | development | testing
SESSION_SECRET=change-me-to-a-long-random-string
# Optional alias: FLASK_SECRET_KEY=

# SQLite (local) or Postgres (prod)
DATABASE_URL=sqlite:///real_estate_crm.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/gptvli

# --- Security ---
ENABLE_CSRF=0
# Set to 1 in production (auto-on when FLASK_ENV=production)
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
# ALLOW_INSECURE_SECRET=0
# ENABLE_CSP=0

# --- UI ---
USE_TAILWIND_CDN=1
# 0 = use static/css/tailwind-ph.css (run: npm run build:css)
# 1 = Tailwind CDN (local UI only)

# --- AI / Gemini ---
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# --- SMS ---
SMS_PROVIDER=log
# melipayamak | log
# MELIPAYAMAK_USERNAME=
# MELIPAYAMAK_PASSWORD=
# MELIPAYAMAK_FROM=

# --- Geocoding ---
GEOCODE_PROVIDER=auto
# auto | nominatim | off
# GEOCODE_USER_AGENT=PlatinumHeritageCRM/1.0 (ops@example.com)

# --- Optional ---
# PREFERRED_URL_SCHEME=https
# SESSION_LIFETIME_SECONDS=43200

# --- Docker Compose (profile: prod) ---
# POSTGRES_USER=gptvli
# POSTGRES_PASSWORD=gptvli_change_me
# POSTGRES_DB=gptvli
# POSTGRES_PORT=5432
# WEB_PORT=8000
# RUN_MIGRATIONS=1
# REDIS_URL=redis://redis:6379/0
